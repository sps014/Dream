// Core comparison interfaces.

// Value equality. `a == b` / `a != b` on a type that implements `Equatable<T>` dispatch here.
public interface Equatable<T> {
    fun equals(other: T): bool;
}

// Total ordering. `compare` returns a negative number when `this < other`, zero when equal, and a positive number otherwise.
public interface Comparable<T> {
    fun compare(other: T): int;
}
