// Cursor produced by `string.iterator()`.
class StringIterator {
    text: string;
    idx: int;

    constructor(text: string) {
        this.text = text;
        this.idx = 0;
    }

    // Yields the next character or None.
    public fun next(): Option<char> {
        if (this.idx >= this.text.size()) {
            return Option.None;
        }
        let value = this.text.char_at(this.idx);
        this.idx = this.idx + 1;
        return Option.Some(value);
    }
}
