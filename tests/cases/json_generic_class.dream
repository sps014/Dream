// @json on a generic class: the derive attaches to the template `Box<T>` and each concrete
// instantiation gets its own `to_json`/`from_json`. Type-parameter fields round-trip through
// `JSON.serialize`/`JSON.deserialize`, which the analyzer resolves per instance, so `Box<Point>`
// delegates to `Point`'s (also `@json`) converters.
@json
struct Point { public x: int; public y: int; constructor(x: int, y: int) { this.x = x; this.y = y; } }

@json
struct Box<T> { public value: T; constructor(value: T) { this.value = value; } }

fun main(): void {
    let b = Box<Point>(Point(3, 4));
    let s = JSON.serialize<Box<Point>>(b);
    System.println(s);
    let back = JSON.deserialize<Box<Point>>(s);
    System.println(back.value.x);
    System.println(back.value.y);
}
