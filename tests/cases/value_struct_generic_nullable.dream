// A generic field substituted to a nullable value struct (`Wrapper<Point>.inner : Point?`) is now
// supported: it boxes to a nullable heap pointer, so `null` is representable per instantiation.

struct Point {
    public x: int;

    constructor(x: int) {
        this.x = x;
    }
}

struct Wrapper<T> {
    public inner: T?;

    constructor(inner: T?) {
        this.inner = inner;
    }
}

fun main(): void {
    let w = Wrapper<Point>(Point(1));
    let p: Point = w.inner ?? Point(-1);
    System.println(p.x);

    let empty = Wrapper<Point>(null);
    let q: Point = empty.inner ?? Point(-1);
    System.println(q.x);
}
