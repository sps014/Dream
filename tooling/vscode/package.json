{
  "name": "dream-lang",
  "version": "0.1.6",
  "description": "Dream language support for VS Code",
  "publisher": "dream-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "./icons/dream.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:dream"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "dream-icons",
        "label": "Dream File Icons",
        "path": "./icon-theme.json"
      }
    ],
    "languages": [
      {
        "id": "dream",
        "extensions": [
          ".dream"
        ],
        "icon": {
          "light": "./icons/dream.svg",
          "dark": "./icons/dream.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "dream",
        "scopeName": "source.dream",
        "path": "./syntaxes/dream.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "dream.runFile",
        "title": "Dream: Run File",
        "icon": "$(play)"
      },
      {
        "command": "dream.showWat",
        "title": "Dream: Show Generated WAT",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dream.runFile",
          "when": "resourceLangId == dream",
          "group": "navigation@1"
        },
        {
          "command": "dream.showWat",
          "when": "resourceLangId == dream",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
