{
  "name": "dream-lang",
  "version": "0.1.6",
  "description": "Dream language support for VS Code",
  "publisher": "dream-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "./icons/dream.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:dream"
  ],
  "contributes": {
    "breakpoints": [
      {
        "language": "dream"
      }
    ],
    "debuggers": [
      {
        "type": "dream",
        "label": "Dream",
        "languages": [
          "dream"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the .dream source file to debug.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause at the first line of the program.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "dream",
            "request": "launch",
            "name": "Dream: Debug current file",
            "program": "${file}",
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Dream: Debug current file",
            "description": "Debug the active .dream file with the Dream debugger",
            "body": {
              "type": "dream",
              "request": "launch",
              "name": "Dream: Debug current file",
              "program": "^\"\\${file}\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ],
    "iconThemes": [
      {
        "id": "dream-icons",
        "label": "Dream File Icons",
        "path": "./icon-theme.json"
      }
    ],
    "languages": [
      {
        "id": "dream",
        "extensions": [
          ".dream"
        ],
        "icon": {
          "light": "./icons/dream.svg",
          "dark": "./icons/dream.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "dream",
        "scopeName": "source.dream",
        "path": "./syntaxes/dream.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "dream.runFile",
        "title": "Dream: Run File",
        "icon": "$(play)"
      },
      {
        "command": "dream.debugFile",
        "title": "Dream: Debug File",
        "icon": "$(debug-alt)"
      },
      {
        "command": "dream.showWat",
        "title": "Dream: Show Generated WAT (Debug)",
        "icon": "$(output)"
      },
      {
        "command": "dream.showWatRelease",
        "title": "Dream: Show Generated WAT (Release)",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dream.runFile",
          "when": "resourceLangId == dream",
          "group": "navigation@1"
        },
        {
          "command": "dream.debugFile",
          "when": "resourceLangId == dream",
          "group": "navigation@2"
        },
        {
          "command": "dream.showWat",
          "when": "resourceLangId == dream",
          "group": "navigation@3"
        },
        {
          "command": "dream.showWatRelease",
          "when": "resourceLangId == dream",
          "group": "navigation@4"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
